# Copy to .env (gitignored) and fill in.

# Tinker API (chat.py, continued_pretrain.py, run_slack_lora_inference.py, …)
TINKER_API_KEY=

# Slack search export (exportSlackMessages.py): browser session token + slack.com "d" cookie
SLACK_XOXC_TOKEN=
SLACK_D_COOKIE=

# Optional: higher Hugging Face Hub rate limits for tokenizer/model downloads
# HF_TOKEN=
