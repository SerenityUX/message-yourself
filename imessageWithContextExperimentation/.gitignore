# =============================================================================
# imessageWithContextExperimentation — copy-friendly .gitignore
# =============================================================================
# Used with the repo root `.gitignore`. See README “Git & environment” in this folder.

.env
.env.*
!.env.example

__pycache__/
*.py[cod]
.venv/
venv/

models/
**/tinker_lora_adapter/
**/tinker_lora_sft_adapter/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt

cpt_out.txt
messages_export.txt

**/sft_tinker_api_dump.json
**/sft_tinker_metadata.json

# experiment_results/ — local only (manifests contain tinker:// + disk paths)
experiment_results/*
!experiment_results/.gitkeep
experiment_results-2/*
!experiment_results-2/.gitkeep
experiment_results-3/*
!experiment_results-3/.gitkeep
