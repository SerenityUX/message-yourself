# =============================================================================
# message-yourself — repository root
# =============================================================================
# Package-specific ignores (venv, this tree’s `sft_output.json`, experiment dumps)
# also live under e.g. `imessageWithContextSelfExperimentation/.gitignore` so each
# folder is self-documenting. Git applies every `.gitignore` from root down.

# --- OS & editors ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
*.swp
*.swo
*~
.idea/
*.sublime-*

# --- Python (global) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual envs ---
.venv/
venv/
ENV/
env/

# --- Secrets (never commit) ---
.env
.env.*
!.env.example
!**/.env.example
!.env*.example
!**/.env*.example
*.pem
*.key
id_rsa
id_rsa.*
*.p12
*.pfx
credentials.json
client_secret*.json
**/secrets/
.secrets/

# --- Test / tool caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.ipynb_checkpoints/

# --- ML artifacts (any subfolder) ---
models/
checkpoints/
checkpoint-*/
outputs/
wandb/
lightning_logs/
mlruns/
tensorboard_logs/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.onnx
*.gguf
*.h5
*.joblib
*.npy
*.npz
**/tinker_lora_adapter/
**/tinker_lora_sft_adapter/

# --- Caches inside repo ---
.cache/
.huggingface/

# --- Large generated text corpora (default: ignore) ---
**/cpt_out.txt
cpt_out.txt
**/sft_output.txt
messages_export.txt
**/sft_output.json

# --- Slack bulk exports ---
my_slack_messages*.json
**/*copy*.json

# --- Tinker: heavy / sensitive API captures ---
**/sft_tinker_api_dump.json
**/cpt_tinker_metadata.json
**/tinker_api_full_response.json
**/rl_tinker_metadata.json

# --- Logs & temp ---
*.log
tmp/
temp/
*.tmp
*.temp
