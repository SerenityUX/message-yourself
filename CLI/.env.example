# Copy to .env (gitignored). Never commit real keys.
# python-dotenv loads .env from this directory when you run scripts here.

# --- Tinker (SFT + Thomas chat completions) ---
TINKER_API_KEY=

# Optional: chat without a trained checkpoint (base model slug).
# TINKER_BASE_MODEL=openai/gpt-oss-120b
# TINKER_CHAT_MODEL_URI=tinker://…/sampler_weights/…
# TINKER_MAX_LORA_RANK=32

# --- OpenRouter (friend roleplay + rubric + agent controller) ---
OPEN_ROUTER_API_KEY=
# Or: OPENROUTER_API_KEY=

OPEN_ROUTER_MODEL=anthropic/claude-sonnet-4.5
OPEN_ROUTER_RATER_MODEL=
OPEN_ROUTER_AGENT_MODEL=

# Optional OpenRouter HTTP metadata (some providers care)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_NAME=message-yourself-experiment

# --- Repro / sweeps (optional) ---
# MESSAGES_EXPERIMENT_FRIEND_TEMPERATURE=0
# MESSAGES_EXPERIMENT_THOMAS_TEMPERATURE=0
# HF_TOKEN=
